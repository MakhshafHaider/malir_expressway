# ── Django ──────────────────────────────────────────────────────────────────
# Use config.settings.production for production deployments
DJANGO_SETTINGS_MODULE=config.settings.local

# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=mtag_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Primary DB host (main server)
DB_HOST=192.168.78.200

# Optional: local fallback — if DB_HOST is unreachable, connects here automatically
# psycopg2 tries DB_HOST first; waits 3s, then falls back to DB_FALLBACK_HOST
# Leave empty to disable fallback (single-host mode)
DB_FALLBACK_HOST=localhost

# ── CORS (production only — list your frontend origin) ───────────────────────
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# ── JazzCash payment gateway ─────────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:8000/api/v1/payments/jazzcash/callback/
