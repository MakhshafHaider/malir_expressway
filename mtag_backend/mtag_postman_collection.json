{
  "info": {
    "name": "M-Tag Toll Collection API",
    "description": "Complete API collection for M-Tag Electronic Toll Collection System — Malir Expressway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" },
    { "key": "plaza_id", "value": "",                      "type": "string" },
    { "key": "vehicle_id","value": "",                     "type": "string" },
    { "key": "account_id","value": "",                     "type": "string" },
    { "key": "tag_serial","value": "E28278022000000032C5A162", "type": "string" }
  ],
  "item": [

    {
      "name": "1. Auth",
      "item": [

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.access) {",
                  "    pm.collectionVariables.set('token', res.data.access);",
                  "    console.log('Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mtag.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/login/", "host": ["{{base_url}}"], "path": ["api","v1","auth","login",""] }
          }
        },

        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"operator@mtag.com\",\n  \"password\": \"operator123\",\n  \"first_name\": \"Ali\",\n  \"last_name\": \"Khan\",\n  \"role\": \"operator\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/register/", "host": ["{{base_url}}"], "path": ["api","v1","auth","register",""] }
          }
        },

        {
          "name": "Me (Profile)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/me/", "host": ["{{base_url}}"], "path": ["api","v1","auth","me",""] }
          }
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/logout/", "host": ["{{base_url}}"], "path": ["api","v1","auth","logout",""] }
          }
        },

        {
          "name": "Admin — User List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/admin/users/", "host": ["{{base_url}}"], "path": ["api","v1","auth","admin","users",""] }
          }
        }

      ]
    },

    {
      "name": "2. Vehicles & Tags",
      "item": [

        {
          "name": "Available Tags (Unassigned)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/vehicles/tags/available/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles","tags","available",""] }
          }
        },

        {
          "name": "Register Vehicle",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "    pm.collectionVariables.set('vehicle_id', res.data.id);",
                  "    console.log('vehicle_id saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plate_number\": \"ABC-123\",\n  \"vehicle_type\": \"car\",\n  \"tag_serial\": \"{{tag_serial}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/vehicles/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles",""] }
          }
        },

        {
          "name": "Vehicle List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/vehicles/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles",""] }
          }
        },

        {
          "name": "Vehicle by Plate Number",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/vehicles/plate/ABC-123/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles","plate","ABC-123",""] }
          }
        },

        {
          "name": "Vehicle Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/vehicles/{{vehicle_id}}/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles","{{vehicle_id}}",""] }
          }
        },

        {
          "name": "Vehicle Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/vehicles/{{vehicle_id}}/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles","{{vehicle_id}}",""] }
          }
        },

        {
          "name": "Tag Reissue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tag_serial\": \"E28278022000000032C5A163\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/vehicles/tags/{{vehicle_id}}/reissue/", "host": ["{{base_url}}"], "path": ["api","v1","vehicles","tags","{{vehicle_id}}","reissue",""] }
          }
        }

      ]
    },

